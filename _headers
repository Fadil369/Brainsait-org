/*
  # Security Headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  
  # Performance & Caching
  Cache-Control: public, max-age=3600, stale-while-revalidate=604800
  
  # SEO Headers
  Vary: Accept-Encoding, Accept-Language
  
  # Content Security Policy - Enhanced
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://js.stripe.com https://www.paypal.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://api.brainsait.org https://partners-api.brainsait.org; frame-src https://js.stripe.com https://www.paypal.com

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=604800
  Content-Type: application/javascript

/*.css
  Cache-Control: public, max-age=604800
  Content-Type: text/css

/favicon.ico
  Cache-Control: public, max-age=86400

/og-image.png
  Cache-Control: public, max-age=2592000
