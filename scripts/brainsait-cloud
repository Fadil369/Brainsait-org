#!/usr/bin/env zsh
# BrainSAIT Cloud Infrastructure Manager

set -e

VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Server definitions
typeset -A SERVERS
SERVERS=(
    hetzner "hetzner.elfadil.com|fadil369|Hetzner Production|46.62.128.198"
    nphies "nphies-ssh.elfadil.com|root|NPHIES Healthcare|82.25.101.65"
    mac "mac.elfadil.com|fadil369|Mac Development|local"
    pi "pi.elfadil.com|pi|Raspberry Pi|local"
)

print_header() {
    echo -e "${CYAN}"
    cat << 'EOF'
╔══════════════════════════════════════════════════════════╗
║                                                           ║
║     ██████╗ ██████╗  █████╗ ██╗███╗   ██╗███████╗       ║
║     ██╔══██╗██╔══██╗██╔══██╗██║████╗  ██║██╔════╝       ║
║     ██████╔╝██████╔╝███████║██║██╔██╗ ██║███████╗       ║
║     ██╔══██╗██╔══██╗██╔══██║██║██║╚██╗██║╚════██║       ║
║     ██████╔╝██║  ██║██║  ██║██║██║ ╚████║███████║       ║
║     ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝╚═╝  ╚═══╝╚══════╝       ║
║                                                           ║
║              Cloud Infrastructure Manager                 ║
║                   Version 1.0.0                          ║
║                                                           ║
╚══════════════════════════════════════════════════════════╝
EOF
    echo -e "${NC}"
}

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_error() { echo -e "${RED}✗${NC} $1"; }
print_warning() { echo -e "${YELLOW}⚠${NC} $1"; }
print_info() { echo -e "${BLUE}ℹ${NC} $1"; }

cmd_status() {
    print_header
    echo -e "${YELLOW}Infrastructure Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    for name in "${!SERVERS[@]}"; do
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$name]}"
        printf "${CYAN}%-12s${NC} " "$name:"
        printf "${PURPLE}%-20s${NC} " "$desc"
        
        if timeout 5 ssh -o BatchMode=yes -o ConnectTimeout=5 "$hostname" "exit" 2>/dev/null; then
            uptime=$(ssh "$hostname" "uptime -p" 2>/dev/null | sed 's/up //' || echo "unknown")
            load=$(ssh "$hostname" "uptime" 2>/dev/null | awk -F'load average:' '{print $2}' | xargs || echo "unknown")
            print_success "Online │ Uptime: $uptime │ Load: $load"
        else
            print_error "Offline or unreachable"
        fi
    done
    
    echo ""
    echo -e "${YELLOW}Cloudflare Tunnels${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    cloudflared tunnel list 2>/dev/null || print_warning "Unable to fetch tunnel status"
}

cmd_ssh() {
    local target="$1"
    
    if [[ -z "$target" ]]; then
        echo -e "${YELLOW}Available servers:${NC}"
        for name in "${!SERVERS[@]}"; do
            IFS='|' read -r hostname user desc ip <<< "${SERVERS[$name]}"
            echo -e "  ${GREEN}$name${NC} - $desc ($ip)"
        done
        exit 0
    fi
    
    if [[ -n "${SERVERS[$target]}" ]]; then
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$target]}"
        echo -e "${BLUE}Connecting to $desc...${NC}"
        ssh "$hostname"
    else
        print_error "Unknown server: $target"
        echo "Run: brainsait-cloud ssh (to see available servers)"
        exit 1
    fi
}

cmd_exec() {
    local target="$1"
    shift
    local command="$*"
    
    if [[ -z "$command" ]]; then
        print_error "Usage: brainsait-cloud exec <server|all> <command>"
        exit 1
    fi
    
    if [[ "$target" == "all" ]]; then
        for name in "${!SERVERS[@]}"; do
            IFS='|' read -r hostname user desc ip <<< "${SERVERS[$name]}"
            echo -e "\n${CYAN}▶ $name ($desc):${NC}"
            ssh -o ConnectTimeout=5 "$hostname" "$command" 2>&1 || print_error "Failed"
        done
    elif [[ -n "${SERVERS[$target]}" ]]; then
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$target]}"
        ssh "$hostname" "$command"
    else
        print_error "Unknown server: $target"
        exit 1
    fi
}

cmd_tunnel() {
    local action="${1:-status}"
    
    case "$action" in
        list|status)
            print_header
            echo -e "${YELLOW}Cloudflare Tunnel Information${NC}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            cloudflared tunnel list
            echo ""
            cloudflared tunnel info brainsait-infrastructure 2>/dev/null || true
            ;;
        metrics)
            echo -e "${YELLOW}Tunnel Metrics:${NC}"
            curl -s http://localhost:2000/metrics | grep -E "^cloudflared_" | head -20
            ;;
        restart)
            print_warning "Restarting Cloudflare Tunnel on all servers..."
            cmd_exec all "sudo systemctl restart cloudflared 2>/dev/null || sudo launchctl unload /Library/LaunchDaemons/com.cloudflare.cloudflared.plist && sudo launchctl load /Library/LaunchDaemons/com.cloudflare.cloudflared.plist 2>/dev/null || true"
            print_success "Tunnels restart initiated"
            ;;
        *)
            echo "Usage: brainsait-cloud tunnel <list|status|metrics|restart>"
            ;;
    esac
}

cmd_deploy() {
    local server="$1"
    local app="${2:-.}"
    local branch="${3:-main}"
    
    if [[ -z "$server" ]]; then
        print_error "Usage: brainsait-cloud deploy <server> [app-path] [branch]"
        exit 1
    fi
    
    if [[ -n "${SERVERS[$server]}" ]]; then
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$server]}"
        print_header
        echo -e "${GREEN}Deploying to $desc${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        
        # Sync code
        print_info "Syncing code..."
        rsync -avz --exclude='node_modules' --exclude='.git' "$app/" "$hostname:~/app/"
        
        # Run deploy script if exists
        ssh "$hostname" "cd ~/app && git pull origin $branch 2>/dev/null || true"
        ssh "$hostname" "cd ~/app && npm install 2>/dev/null || pip3 install -r requirements.txt 2>/dev/null || true"
        
        print_success "Deployment complete!"
    else
        print_error "Unknown server: $server"
        exit 1
    fi
}

cmd_logs() {
    local server="$1"
    local logtype="${2:-cloudflared}"
    
    if [[ -z "$server" ]]; then
        print_error "Usage: brainsait-cloud logs <server> [cloudflared|nginx|syslog]"
        exit 1
    fi
    
    if [[ -n "${SERVERS[$server]}" ]]; then
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$server]}"
        echo -e "${BLUE}Fetching logs from $desc...${NC}"
        
        case "$logtype" in
            cloudflared)
                ssh "$hostname" "sudo journalctl -u cloudflared -f --lines=50"
                ;;
            nginx)
                ssh "$hostname" "sudo tail -f /var/log/nginx/access.log /var/log/nginx/error.log"
                ;;
            syslog)
                ssh "$hostname" "sudo tail -f /var/log/syslog"
                ;;
            *)
                ssh "$hostname" "sudo tail -f $logtype"
                ;;
        esac
    else
        print_error "Unknown server: $server"
        exit 1
    fi
}

cmd_info() {
    print_header
    cat << EOF
${YELLOW}Infrastructure Details${NC}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

${CYAN}Domains:${NC}
  • elfadil.com       - Primary domain (Cloudflare)
  • brainsait.cloud   - Infrastructure domain (Hetzner)

${CYAN}Servers:${NC}
EOF
    
    for name in "${!SERVERS[@]}"; do
        IFS='|' read -r hostname user desc ip <<< "${SERVERS[$name]}"
        echo -e "  ${GREEN}$name${NC}"
        echo -e "    Description: $desc"
        echo -e "    Hostname:    $hostname"
        echo -e "    IP:          $ip"
        echo -e "    User:        $user"
        echo ""
    done
    
    cat << EOF
${CYAN}Quick Commands:${NC}
  SSH:      ssh hetzner  |  ssh nphies  |  ssh pi
  Web:      https://brainsait.cloud
  API:      https://api.elfadil.com
  Monitor:  https://monitor.elfadil.com
  NPHIES:   https://nphies.elfadil.com

${CYAN}Zero Trust Dashboard:${NC}
  https://one.dash.cloudflare.com
EOF
}

cmd_help() {
    print_header
    cat << EOF
${YELLOW}Usage:${NC} brainsait-cloud <command> [options]

${CYAN}Commands:${NC}
  ${GREEN}status${NC}                    Show infrastructure status
  ${GREEN}ssh <server>${NC}              SSH into a server
  ${GREEN}exec <server|all> <cmd>${NC}   Execute command on server(s)
  ${GREEN}tunnel <action>${NC}           Manage Cloudflare Tunnels
  ${GREEN}deploy <server> [app]${NC}     Deploy application to server
  ${GREEN}logs <server> [type]${NC}      View server logs
  ${GREEN}info${NC}                      Show infrastructure details
  ${GREEN}help${NC}                      Show this help message

${CYAN}Examples:${NC}
  brainsait-cloud status
  brainsait-cloud ssh hetzner
  brainsait-cloud exec all "df -h"
  brainsait-cloud tunnel restart
  brainsait-cloud deploy hetzner ~/my-app
  brainsait-cloud logs nphies cloudflared

${CYAN}Servers:${NC}
  hetzner  - Hetzner production (46.62.128.198)
  nphies   - NPHIES healthcare (82.25.101.65)
  mac      - Mac development
  pi       - Raspberry Pi

${CYAN}Learn more:${NC}
  Documentation: ~/brainsait-cloud-infrastructure.md
  Support: dr.mf.12298@gmail.com
EOF
}

# Main
main() {
    local command="${1:-help}"
    shift || true
    
    case "$command" in
        status) cmd_status "$@" ;;
        ssh) cmd_ssh "$@" ;;
        exec) cmd_exec "$@" ;;
        tunnel) cmd_tunnel "$@" ;;
        deploy) cmd_deploy "$@" ;;
        logs) cmd_logs "$@" ;;
        info) cmd_info "$@" ;;
        help|--help|-h) cmd_help "$@" ;;
        *)
            print_error "Unknown command: $command"
            echo "Run 'brainsait-cloud help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
