# Redis Stack self-host defaults
REDIS_STACK_PORT=6379
REDIS_STACK_HTTP_PORT=8001
REDIS_PASSWORD=change-me-now
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lfu
REDIS_APPEND_FSYNC=everysec
REDIS_SAVE_SCHEDULE=900 1 300 10 60 10000
REDIS_DATA_RETENTION_DAYS=7

# Redis Insight (optional)
REDIS_INSIGHT_PORT=5540

# Sentinel/HA mode defaults
REDIS_MASTER_NAME=brainsait-master
REDIS_SENTINEL_QUORUM=2
REDIS_SENTINEL_PORT1=26379
REDIS_SENTINEL_PORT2=26380
REDIS_SENTINEL_PORT3=26381
