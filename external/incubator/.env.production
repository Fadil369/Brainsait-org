# BrainSAIT Platform Production Environment Configuration
# WARNING: Keep this file secure and never commit to version control

# ===========================================
# GENERAL PRODUCTION CONFIGURATION
# ===========================================
NODE_ENV=production
PLATFORM_NAME=BrainSAIT Platform
DOMAIN=brainsait.com
SUBDOMAIN=www

# ===========================================
# FRONTEND CONFIGURATION (brainsait-frontend)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.brainsait.com
NEXT_PUBLIC_DOCS_URL=https://docs.brainsait.com
NEXT_PUBLIC_AI_URL=https://ai.brainsait.com
NEXT_PUBLIC_APP_URL=https://brainsait.com

# Feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_REAL_TIME_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SAUDI_COMPLIANCE=true

# ===========================================
# BACKEND CONFIGURATION (brainsait-backend)
# ===========================================
PORT=5000

# Production Database Configuration
DATABASE_URL=postgresql://brainsait_user:SECURE_PASSWORD_HERE@your-db-server:5432/brainsait_production
DATABASE_HOST=your-db-server
DATABASE_PORT=5432
DATABASE_NAME=brainsait_production
DATABASE_USER=brainsait_user
DATABASE_PASSWORD=SECURE_PASSWORD_HERE

# Production Redis Configuration
REDIS_URL=redis://:REDIS_PASSWORD_HERE@your-redis-server:6379
REDIS_HOST=your-redis-server
REDIS_PORT=6379
REDIS_PASSWORD=REDIS_PASSWORD_HERE

# JWT Configuration - CHANGE THESE IN PRODUCTION
JWT_SECRET=SECURE_JWT_SECRET_MINIMUM_32_CHARACTERS_PRODUCTION_ONLY
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGINS=https://brainsait.com,https://www.brainsait.com,https://app.brainsait.com

# ===========================================
# AI SERVICE CONFIGURATION
# ===========================================
AI_PORT=5001

# OpenAI Configuration - PRODUCTION KEYS
OPENAI_API_KEY=sk-prod-your-production-openai-api-key-here
OPENAI_ORG_ID=org-your-production-org-id-here
OPENAI_PROJECT_ID=proj_your-production-project-id-here

# Anthropic Claude Configuration - PRODUCTION KEYS
CLAUDE_API_KEY=sk-ant-your-production-claude-api-key-here

# AI Feature Flags
ENABLE_AI_CLAIMS=true
ENABLE_AI_COMPLIANCE=true
ENABLE_AI_DOCUMENTATION=true
ENABLE_AI_CONTACT_CENTER=true
ENABLE_AI_KNOWLEDGE=true

# Production AI Limits and Quotas
MAX_TOKENS_PER_REQUEST=4000
MAX_REQUESTS_PER_MINUTE=200
AI_USAGE_QUOTA_PER_USER=50000
AI_RATE_LIMIT_WINDOW=3600000
AI_RATE_LIMIT_MAX=500

# Vector Database (Production)
VECTOR_DB_URL=https://your-production-vector-db-url.com
VECTOR_DB_API_KEY=your-production-vector-db-api-key

# ===========================================
# DOCUMENT SERVICE (brainsait-docs)
# ===========================================
DOCS_PORT=5002
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
TEMPLATES_PATH=./templates
OUTPUT_PATH=./output
TEMP_PATH=./temp

# ===========================================
# EMAIL CONFIGURATION (Production)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@brainsait.com
SMTP_PASS=YOUR_PRODUCTION_EMAIL_APP_PASSWORD
EMAIL_FROM=noreply@brainsait.com

# SendGrid (Alternative - Production)
SENDGRID_API_KEY=SG.YOUR_PRODUCTION_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@brainsait.com

# ===========================================
# FILE UPLOAD CONFIGURATION (Production)
# ===========================================
MAX_FILE_SIZE=52428800  # 50MB for production
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ===========================================
# SECURITY CONFIGURATION (Production)
# ===========================================
BCRYPT_SALT_ROUNDS=14  # Higher for production
RATE_LIMIT_WINDOW=900000  # 15 minutes
RATE_LIMIT_MAX=1000  # Higher for production
SESSION_SECRET=SECURE_SESSION_SECRET_PRODUCTION_MINIMUM_64_CHARACTERS_LONG

# ===========================================
# SSL/TLS CONFIGURATION
# ===========================================
SSL_CERT_PATH=/path/to/ssl/certificate.pem
SSL_KEY_PATH=/path/to/ssl/private-key.pem
SSL_CA_PATH=/path/to/ssl/ca-certificate.pem

# Force HTTPS
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

# ===========================================
# CLOUD STORAGE (Production)
# ===========================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=YOUR_PRODUCTION_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_PRODUCTION_AWS_SECRET_KEY
AWS_REGION=me-central-1  # Middle East (UAE) for better performance
AWS_S3_BUCKET=brainsait-production-files

# Cloudflare R2 (Alternative)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=brainsait-documents

# ===========================================
# ANALYTICS & MONITORING (Production)
# ===========================================
# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-public-sentry-dsn@sentry.io/project-id
SENTRY_ORG=brainsait
SENTRY_PROJECT=brainsait-platform

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=your-app-insights-key
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-app-insights-key

# ===========================================
# PAYMENT PROCESSING (Production)
# ===========================================
# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_production_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# PayTabs (Saudi Arabia)
PAYTABS_PROFILE_ID=your-paytabs-profile-id
PAYTABS_SERVER_KEY=your-paytabs-server-key
PAYTABS_CLIENT_KEY=your-paytabs-client-key

# ===========================================
# SAUDI GOVERNMENT INTEGRATIONS
# ===========================================
# Ministry of Health (MOH) API
MOH_API_URL=https://api.moh.gov.sa
MOH_API_KEY=your-moh-api-key
MOH_CLIENT_ID=your-moh-client-id

# NPHIES (National Platform for Health Information Exchange)
NPHIES_BASE_URL=https://api.nphies.sa
NPHIES_CLIENT_ID=your-nphies-client-id
NPHIES_CLIENT_SECRET=your-nphies-client-secret
NPHIES_CERTIFICATE_PATH=/path/to/nphies/certificate.p12
NPHIES_CERTIFICATE_PASSWORD=your-certificate-password

# Ministry of Commerce (for CR validation)
MOC_API_URL=https://api.mci.gov.sa
MOC_API_KEY=your-moc-api-key

# ZATCA (for VAT validation)
ZATCA_API_URL=https://api.zatca.gov.sa
ZATCA_API_KEY=your-zatca-api-key

# WASL (Address verification)
WASL_API_URL=https://api.wasl.sa
WASL_API_KEY=your-wasl-api-key

# ===========================================
# LOGGING CONFIGURATION (Production)
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json  # Structured logging for production
LOG_DATE_PATTERN=YYYY-MM-DD
LOG_MAX_SIZE=100m
LOG_MAX_FILES=30d

# External logging service
LOG_SERVICE_URL=https://your-log-service.com/api/logs
LOG_SERVICE_API_KEY=your-log-service-api-key

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
# Database Backup
DB_BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_S3_BUCKET=brainsait-db-backups

# File Backup
FILE_BACKUP_SCHEDULE=0 3 * * *  # Daily at 3 AM
FILE_BACKUP_RETENTION_DAYS=90

# ===========================================
# CDN CONFIGURATION
# ===========================================
CDN_URL=https://cdn.brainsait.com
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ===========================================
# CONTAINER ORCHESTRATION
# ===========================================
# Kubernetes
KUBE_NAMESPACE=brainsait-production
KUBE_CONFIG_PATH=/path/to/kubeconfig

# Docker Registry
DOCKER_REGISTRY=registry.brainsait.com
DOCKER_USERNAME=your-registry-username
DOCKER_PASSWORD=your-registry-password

# ===========================================
# HEALTH CHECK CONFIGURATION
# ===========================================
HEALTH_CHECK_INTERVAL=30000  # 30 seconds
HEALTH_CHECK_TIMEOUT=5000    # 5 seconds
HEALTH_CHECK_RETRIES=3

# External health check service
HEALTH_CHECK_URL=https://healthchecks.io/ping/your-health-check-uuid

# ===========================================
# CACHE CONFIGURATION
# ===========================================
# Redis Cache TTL
CACHE_DEFAULT_TTL=3600  # 1 hour
CACHE_USER_SESSION_TTL=86400  # 24 hours
CACHE_API_RESPONSE_TTL=300  # 5 minutes

# Cloudflare Cache
CF_CACHE_EVERYTHING=true
CF_BROWSER_CACHE_TTL=31536000  # 1 year for static assets

# ===========================================
# COMPLIANCE AND AUDIT
# ===========================================
# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=365

# GDPR Compliance
GDPR_ENABLED=true
DATA_RETENTION_DAYS=2555  # 7 years (Saudi requirement)

# PCI DSS (if handling payments)
PCI_DSS_ENABLED=true
PCI_LOG_LEVEL=info

# ===========================================
# NOTIFICATION SERVICES
# ===========================================
# Push notifications
FIREBASE_ADMIN_SDK_PATH=/path/to/firebase-admin-sdk.json
FIREBASE_PROJECT_ID=brainsait-platform

# SMS (for Saudi numbers)
SMS_PROVIDER=UNIFONIC
UNIFONIC_APP_SID=your-unifonic-app-sid
UNIFONIC_API_KEY=your-unifonic-api-key

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ===========================================
# FEATURE FLAGS
# ===========================================
FEATURE_AI_ENABLED=true
FEATURE_COMPLIANCE_CHECKS=true
FEATURE_DOCUMENT_GENERATION=true
FEATURE_REAL_TIME_CHAT=true
FEATURE_MOBILE_APP=false
FEATURE_BETA_FEATURES=false

# ===========================================
# SCALABILITY CONFIGURATION
# ===========================================
# Auto-scaling
MIN_INSTANCES=2
MAX_INSTANCES=10
TARGET_CPU_UTILIZATION=70

# Load balancer
LB_ALGORITHM=round_robin
LB_HEALTH_CHECK_PATH=/health
LB_HEALTH_CHECK_INTERVAL=30

# ===========================================
# SECRETS ROTATION
# ===========================================
# Rotation schedule (cron format)
JWT_SECRET_ROTATION_SCHEDULE=0 0 1 */3 *  # Every 3 months
API_KEY_ROTATION_SCHEDULE=0 0 1 */6 *     # Every 6 months
CERT_RENEWAL_SCHEDULE=0 0 1 */2 *         # Every 2 months

# ===========================================
# NOTES FOR DEPLOYMENT
# ===========================================
# 1. Replace ALL placeholder values with actual production credentials
# 2. Store sensitive values in secure secret management system
# 3. Use different passwords for each service
# 4. Enable SSL/TLS for all connections
# 5. Configure firewall rules to allow only necessary traffic
# 6. Set up monitoring and alerting for all services
# 7. Implement automated backups with tested restore procedures
# 8. Configure log aggregation and monitoring
# 9. Set up health checks for all services
# 10. Test disaster recovery procedures