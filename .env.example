# BrainSAIT Platform Environment Configuration
# Copy this file to .env and update the values for your environment

# ===========================================
# GENERAL CONFIGURATION
# ===========================================
NODE_ENV=development
PLATFORM_NAME=BrainSAIT Platform

# ===========================================
# FRONTEND CONFIGURATION (brainsait-frontend)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_DOCS_URL=http://localhost:5002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# BACKEND CONFIGURATION (brainsait-backend)
# ===========================================
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://brainsait:password123@localhost:5432/brainsait_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=brainsait_db
DATABASE_USER=brainsait
DATABASE_PASSWORD=password123

# Redis Configuration
REDIS_URL=redis://:redis123@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-environment
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://brainsait.com

# ===========================================
# DOCUMENT SERVICE (brainsait-docs)
# ===========================================
DOCS_PORT=5002
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=
TEMPLATES_PATH=./templates
OUTPUT_PATH=./output
TEMP_PATH=./temp

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@brainsait.com

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
SESSION_SECRET=your-session-secret-key

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DATE_PATTERN=YYYY-MM-DD-HH
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ===========================================
# THIRD PARTY SERVICES
# ===========================================
# AWS S3 (for file storage - optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=brainsait-files

# SendGrid (for email - alternative to SMTP)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@brainsait.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stripe (for payments - optional)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Sentry (for error tracking - optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Database seeding
SEED_ADMIN_EMAIL=admin@brainsait.com
SEED_ADMIN_PASSWORD=admin123

# Debug settings
DEBUG=brainsait:*
VERBOSE_LOGGING=false

# ===========================================
# PRODUCTION ONLY
# ===========================================
# SSL Configuration
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=

# Domain configuration
DOMAIN=brainsait.com
SUBDOMAIN=www

# CDN Configuration
CDN_URL=https://cdn.brainsait.com